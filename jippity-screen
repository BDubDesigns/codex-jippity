#!/usr/bin/env bash
set -euo pipefail

TMPDIR="${TMPDIR:-/tmp}/jippity"
mkdir -p "$TMPDIR"

STAMP=$(date +%s)
SCREENSHOT="$TMPDIR/screen_$STAMP.png"
OUTFILE="$TMPDIR/response_$STAMP.txt"
LOGFILE="$TMPDIR/last_run_$STAMP.log"

spectacle -f -b -n -o "$SCREENSHOT"
if [ ! -f "$SCREENSHOT" ]; then
    kdialog --error "Screenshot was not created."
    exit 1
fi

PROMPT=$(kdialog --inputbox "Ask about this screen:")
if [ $? -ne 0 ] || [ -z "$PROMPT" ]; then
    exit 0
fi

if ! codex exec -i "$SCREENSHOT" -o "$OUTFILE" -- "$PROMPT" > "$LOGFILE" 2>&1; then
    kdialog --error "Codex exited with an error. See $LOGFILE for details."
    exit 1
fi

WIDTH=800
LINES=$(wc -l < "$OUTFILE")
HEIGHT=$(( LINES * 22 + 100 ))
[ "$HEIGHT" -lt 200 ] && HEIGHT=200
[ "$HEIGHT" -gt 800 ] && HEIGHT=800
kdialog --title "Jippity Response" --geometry "${WIDTH}x${HEIGHT}" --textbox "$OUTFILE"
